@cocotb.test()
async def test_reset_mid_sequence(dut):
    cocotb.start_soon(Clock(dut.clk, 10, units = "ns").start())
    dut.areset.value = 1
    await RisingEdge(dut.clk)
    dut.areset.value = 0
    for i in range(2):
        await RisingEdge(dut.clk)
    dut.areset.value = 1
    await RisingEdge(dut.clk)
    assert dut.curr.value == 0, "The sequence correctly resets to 0"

